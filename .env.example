# ═══════════════════════════════════════════════════════════════
# MaskWise environment variables — PLACEHOLDER VALUES ONLY
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in real values.
# .env is gitignored — it is NEVER committed.
# All vars are prefixed MASKWISE_ to avoid collision with other services
# running on the same host.
# ═══════════════════════════════════════════════════════════════

# ─── App ────────────────────────────────────────────────────────
MASKWISE_APP_ENV=development
# values: development | production
# production turns off /docs interactive UI

MASKWISE_APP_PORT=8005
# internal port — docker-compose maps host 127.0.0.1:8005 to this
# never bind to 0.0.0.0 on host — nginx reverse-proxies the loopback bind

MASKWISE_LOG_LEVEL=INFO
# values: DEBUG | INFO | WARNING | ERROR
# NEVER set to DEBUG in production — risk of logging request bodies

# ─── Auth (Phase 1) ─────────────────────────────────────────────
MASKWISE_API_KEYS=replace-with-real-key,another-real-key
# comma-separated list of valid API keys
# generate each one with: openssl rand -hex 32  → 64-char hex string
# one key per user — revoke by removing the entry and restarting container
# DO NOT use the placeholder above in production

# ─── Rate limit (Phase 1) ───────────────────────────────────────
MASKWISE_RATE_LIMIT=60/minute
# slowapi format: "<count>/<period>" — e.g. "60/minute", "1000/hour"
# applied per client IP, before the auth check
# stops brute-force key guessing at the rate-limit door

# ═══════════════════════════════════════════════════════════════
# Vars below land in later phases — NOT used by Phase 1 code
# ═══════════════════════════════════════════════════════════════

# ─── Redis (Phase 2 — session store, distributed rate limit) ────
# MASKWISE_REDIS_HOST=redis
# MASKWISE_REDIS_PORT=6379
# MASKWISE_REDIS_PASSWORD=
# MASKWISE_SESSION_TTL_SECONDS=3600

# ─── Postgres (Phase 2 — user accounts, usage stats) ────────────
# MASKWISE_POSTGRES_USER=maskwise_app
# MASKWISE_POSTGRES_PASSWORD=
# MASKWISE_POSTGRES_DB=maskwise
# MASKWISE_POSTGRES_HOST=postgres
# MASKWISE_POSTGRES_PORT=5432

# ─── CORS (Phase 2 — dashboard frontend) ────────────────────────
# MASKWISE_ALLOWED_ORIGINS=https://maskwise.nakularora.tech

# ─── Observability (Phase 2+) ───────────────────────────────────
# MASKWISE_SENTRY_DSN=
