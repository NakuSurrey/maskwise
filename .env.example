# ═══════════════════════════════════════════════════════════════
# MaskWise environment variables — PLACEHOLDER VALUES ONLY
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in real values.
# .env is gitignored — it is NEVER committed.
# Real passwords go in .env only.
# ═══════════════════════════════════════════════════════════════

# ─── App ────────────────────────────────────────────────────────
APP_ENV=development
# values: development | production
# affects logging level, debug routes, CORS rules

APP_PORT=8005
# internal port the FastAPI container listens on
# bound to 127.0.0.1 on the host — never 0.0.0.0
# host port = container port for simplicity

LOG_LEVEL=INFO
# values: DEBUG | INFO | WARNING | ERROR
# NEVER set to DEBUG in production — risk of logging request bodies

# ─── Redis (session store for /unmask, TTL 1h) ──────────────────
REDIS_HOST=redis
# inside docker network — container name resolves automatically
# from the host (you) → 127.0.0.1
# from the api container → "redis"

REDIS_PORT=6379
# default redis port — INSIDE container only
# host-side port mapping uses a random high port (see docker-compose.yml)

REDIS_PASSWORD=changeme_redis_password_32_chars_min
# generate real value: openssl rand -base64 32 | tr -d '=+/' | cut -c1-32

SESSION_TTL_SECONDS=3600
# how long a mask session lives in redis before auto-deletion
# 3600 = 1 hour. Matches privacy promise on landing page.

# ─── Postgres (Phase 2+, stats only — NO user input) ────────────
POSTGRES_USER=maskwise_app
# dedicated app user — NOT the superuser
# NHS reference §27 lesson: never give app the superuser role

POSTGRES_PASSWORD=changeme_postgres_password_32_chars_min
# generate real value: openssl rand -base64 32 | tr -d '=+/' | cut -c1-32

POSTGRES_DB=maskwise_stats
# database name — stats only, never user input

POSTGRES_HOST=postgres
# container name — resolves inside docker network

POSTGRES_PORT=5432
# inside container only — host-side maps to random high port

# ─── Rate limiting ──────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
# requests per IP per minute — prevents abuse and brute-force on /verify-erasure

# ─── CORS ───────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://maskwise.nakularora.tech
# comma-separated. localhost added automatically in dev mode.

# ─── Optional (Phase 2+) ────────────────────────────────────────
# WANDB_API_KEY=                  # for fine-tuning experiment tracking
# HUGGINGFACE_TOKEN=              # for downloading base DeBERTa model
# SENTRY_DSN=                     # error tracking (with PII scrubbing)
